[Unit]
Description=pi-route LLM API router
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
User=pirouted
Group=pirouted
ExecStart=/usr/local/bin/pi-route serve
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure

# Config is a flat file; state dir is created + exported as $STATE_DIRECTORY.
Environment=PI_ROUTE_CONFIG=/etc/pi-route.yml
StateDirectory=pi-route

# Gate token appears at $CREDENTIALS_DIRECTORY/pi_route_token (ramfs, 0400, not inherited).
LoadCredential=pi_route_token:/etc/pi-route.token

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
SystemCallFilter=@system-service
# MemoryDenyWriteExecute is deliberately omitted — it breaks Bun/JSC's JIT.
# For ports < 1024, add:
# AmbientCapabilities=CAP_NET_BIND_SERVICE
# CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
