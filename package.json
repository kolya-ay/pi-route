{
  "name": "pi-router",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./serve": "./src/serve.ts"
  },
  "bin": {
    "pi-route": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch src/serve.ts",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "check": "bun run lint && tsgo --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint-staged",
    "pre-push": "tsgo --noEmit"
  },
  "lint-staged": {
    "*.{ts,json}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.73.0",
    "hono": "^4.12.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "latest",
    "@typescript/native-preview": "7.0.0-dev.20260506.1",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1"
  }
}
