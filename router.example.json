{
  "authDir": "~/.config/pi-route/auth",
  "providers": {
    "claude-direct": {
      "type": "anthropic",
      "accounts": [
        { "type": "claude-cli", "name": "personal", "tokenPath": "~/.claude/credentials.json" }
      ],
      "balancing": { "strategy": "sticky", "rateLimitPerModel": true }
    },
    "antigravity": {
      "type": "antigravity",
      "accounts": [{ "type": "antigravity-oauth", "name": "user@gmail.com" }],
      "balancing": { "strategy": "round-robin" }
    }
  },
  "routing": {
    "rules": [{ "match": "claude-*", "provider": "claude-direct" }],
    "default": { "provider": "claude-direct" }
  }
}
